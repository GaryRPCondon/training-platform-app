# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# LLM interaction logs (keep the folder, ignore contents)
logs/*
!logs/.gitkeep

# Dev-only generated plan validation outputs
validation-runs/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# MCP servers (external dependencies)
garmin-connect-mcp/
strava-mcp/

# documentation templates
docs/
docs/templates/
# public/templates/ contents are seed-only (authored elsewhere) except for bespoke
# templates authored in this repo. Use glob + negation so exceptions take effect.
public/templates/*
!public/templates/bespoke_post_marathon_10k_template.json
!public/templates/10k_plan_catalog.json

# database backups
backups/
backup-schema*.sql

# screenshots
bugscreens/


.claude/
cc_command.txt
temp_strava_original.txt
build_log.txt
build_output.txt
remote_schema.sql
*.code-workspace
